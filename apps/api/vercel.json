{
  "version": 2,
  "builds": [
    {
      "src": "src/serverless.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/schema.prisma", "prisma.config.ts", "node_modules/.prisma/**", "node_modules/@prisma/client/**", "node_modules/@prisma/adapter-pg/**", "node_modules/@prisma/client-engine-runtime/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "src/serverless.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/serverless.ts"
    }
  ]
}
